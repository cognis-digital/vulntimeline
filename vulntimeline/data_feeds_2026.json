      "threat-intel": ["c2detect", "exfilwatch", "modpot", "keyhunt"],
      "compliance": ["stigsentry", "fedramplens", "oscalkit", "comint-osquery", "cisbench", "grcforge", "compliance-atlas", "frameworkmap", "rmf-package", "checkpoint-ai", "aicard", "agenttax"],
