    {"id": "epss", "name": "FIRST EPSS exploit-probability scores", "domain": "vuln", "url": "https://api.first.org/data/v1/epss", "method": "GET", "format": "json", "keyless": true, "cadence": "daily", "notes": "Per-CVE probability of exploitation in next 30d; query ?cve=CVE-... or ?limit=N."},
    {"id": "osv", "name": "OSV.dev vulnerability query", "domain": "vuln", "url": "https://api.osv.dev/v1/query", "method": "POST", "format": "json", "keyless": true, "cadence": "continuous", "bulk": "https://osv-vulnerabilities.storage.googleapis.com/{ecosystem}/all.zip", "notes": "Package+version -> known vulns across ecosystems (PyPI/npm/Go/Maven/...)."},
    {"id": "nvd-cve", "name": "NIST NVD CVE API 2.0", "domain": "vuln", "url": "https://services.nvd.nist.gov/rest/json/cves/2.0", "method": "GET", "format": "json", "keyless": true, "cadence": "continuous", "notes": "Authoritative CVE detail; keyless is rate-limited (5 req/30s) — an NVD_API_KEY raises limits."},
    {"id": "attack-enterprise", "name": "MITRE ATT&CK Enterprise (STIX 2.1)", "domain": "threat-intel", "url": "https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/enterprise-attack/enterprise-attack.json", "method": "GET", "format": "stix", "keyless": true, "cadence": "release", "variants": {"mobile": "https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/mobile-attack/mobile-attack.json", "ics": "https://raw.githubusercontent.com/mitre-attack/attack-stix-data/master/ics-attack/ics-attack.json"}, "notes": "~53MB; technique/tactic/mitigation graph for ATT&CK enrichment & mapping."},
    {"id": "feodo-c2", "name": "abuse.ch Feodo Tracker C2 IP blocklist", "domain": "threat-intel", "url": "https://feodotracker.abuse.ch/downloads/ipblocklist.json", "method": "GET", "format": "json", "keyless": true, "cadence": "hourly", "notes": "Active botnet C2 IPs (Emotet/Dridex/etc.) — direct feed for c2detect / egress hunting."},
