    {"id": "urlhaus", "name": "abuse.ch URLhaus recent malware URLs", "domain": "threat-intel", "url": "https://urlhaus.abuse.ch/downloads/json_recent/", "method": "GET", "format": "json", "keyless": true, "cadence": "continuous", "notes": "Recently-seen malware-distribution URLs."},
